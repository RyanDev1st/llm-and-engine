# CocoIndex Code (ccc)
/.cocoindex_code/

# Claude Code — local / ephemeral (do not commit)
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/worktrees/

# Archive bin (superseded plans/code/data) — brackets escaped (glob char class)
/legacy \[ignore\]/

# Secrets and local runtime
.env
.env.*
*.pem

# Large ML artifacts — never commit (base weights, runs, engines, GGUF)
src/llm/models/
src/llm/runtime/
runs/
*.gguf
*.safetensors
*.bak
ruvector.db
*.db

# Python caches
__pycache__/
*.pyc

# throwaway inspection scratch (never commit)
scratch_*

# persistent user-memory profiles — runtime state, per-user, never committed
data/memory/
